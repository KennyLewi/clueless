generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Hackathon {
  id                   String    @id
  title                String
  description          String
  organizer            String?
  url                  String    @unique
  contentHash          String
  locationMode         String    // "online" | "in_person" | "hybrid"
  locationCity         String?
  locationCountry      String?
  locationTz           String?
  startsAt             DateTime?
  endsAt               DateTime?
  registrationOpensAt  DateTime?
  registrationClosesAt DateTime?
  prizesTotal          String?
  prizesRaw            String?
  themes               String[]
  eligibility          String?
  registrationProvider String    // RegistrationProvider
  registrationFormUrl  String?
  requiresTeam         Boolean?
  requiresAuth         Boolean?
  knownFields          Json      @default("[]") // FormFieldSpec[]
  sources              Json      @default("[]") // SourceRef[]
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  rankedEvents      RankedEvent[]
  registrationRuns  RegistrationRun[]
}

model UserProfile {
  id              String   @id
  name            String
  email           String   @unique
  school          String?
  resumeUrl       String?
  skills          String[]
  interests       String[]
  locationCity    String?
  locationCountry String?
  willingToTravel Boolean  @default(false)
  travelRegions   String[]
  formAnswers  Json     @default("{}") // Record<string, string>
  voice        Json?                    // UserProfile["voice"] — oneLiner, proudProject, outsideLane, writingSamples
  passwordHash String?                  // bcrypt hash; null for seeded/test users
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  rankedEvents     RankedEvent[]
  registrationRuns RegistrationRun[]
}

model RankedEvent {
  id            String   @id @default(cuid())
  hackathonId   String
  userId        String
  score         Float
  reasons       String[]
  matchedThemes String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  hackathon Hackathon   @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, userId])
}

model RegistrationRun {
  id              String   @id
  userId          String
  hackathonId     String
  runner          String   // "playwright" | "simulang"
  status          String
  plannedActions  Json     @default("[]") // PlannedAction[]
  resolvedFields  Json     @default("[]") // FormFieldSpec[] — playwright-derived, stored at fill time for submit reuse
  screenshots     String[]
  finalScreenshot String?
  confirmationCode String?
  errorStage      String?
  errorMessage    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  hackathon Hackathon   @relation(fields: [hackathonId], references: [id])
  user      UserProfile @relation(fields: [userId], references: [id])
}

model PendingNotification {
  id         String    @id @default(cuid())
  userId     String
  kind       String    // NotifyKind
  payloadRef String
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  @@unique([userId, kind, payloadRef])
  @@index([userId, sentAt])
}
