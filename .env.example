# Copy to .env and fill in. Stored as Zo Secrets in production (Settings > Advanced).

# --- Sponsor APIs ---
EXA_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=        # used by Simulang when it falls back to VLM grounding

# --- Infra (defaults match docker-compose.yml) ---
DATABASE_URL=postgres://earlybirds:earlybirds@localhost:5432/earlybirds
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=earlybirds
S3_SECRET_KEY=earlybirds
S3_BUCKET=earlybirds-artifacts

# --- Gateway ---
PORT=3001
# Shared secret the Zo cron Automations send to /internal/cron/* (X-Cron-Secret header)
CRON_SECRET=dev-cron-secret
